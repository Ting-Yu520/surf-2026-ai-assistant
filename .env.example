# DeepSeek API Key (LLM 文本生成)
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/anthropic
DEEPSEEK_MODEL=deepseek-v4-pro

# Gemini API Key (VLM 视频分析)
